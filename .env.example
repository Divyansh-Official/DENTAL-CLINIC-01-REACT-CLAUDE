# Firebase Admin SDK — download from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Email — use Gmail App Password (not your real password)
# Enable: Google Account > Security > 2FA > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourclinic@gmail.com
SMTP_PASS=your_app_password_here

# Doctor's email — receives all booking notifications
DOCTOR_EMAIL=doctor@whitedental.in
CLINIC_NAME=WhiteDental Clinic

# Doctor dashboard password (change this!)
DOCTOR_SECRET=change_this_secret_password

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

PORT=3001
